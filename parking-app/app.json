{
  "expo": {
    "name": "Parking NS",
    "slug": "parking-ns",
    "scheme": "parkingns",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "platforms": ["android", "web"],
    "splash": {
      "backgroundColor": "#0b1626"
    },
    "android": {
      "package": "rs.parkingns.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Parking NS koristi tvoju lokaciju da prepozna kada si parkirao vozilo, uključujući i dok je aplikacija u pozadini.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "expo-notifications"
    ]
  }
}
